# Shopee Flash Sale Sniper Bot v4 — Environment Variables
# Copy this to .env and fill in your values

# Telegram (optional — leave empty to disable notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Flash sale defaults
DEFAULT_MAX_PRICE=1000
PAYMENT_CHANNEL_ID=8001400
CONCURRENT_REQUESTS=5
SUBTRACT_SECONDS=0.5

# Database path
DATABASE=shopee_sniper.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Monitor mode
MONITOR_INTERVAL=60
MONITOR_PRICE_DROP_THRESHOLD=0.9
